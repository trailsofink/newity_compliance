<div class="max-w-3xl mx-auto mt-8">
  <div class="mb-8">
    <h1 class="text-3xl font-extrabold text-[#1d314c] tracking-tight">Profile Dashboard</h1>
    <p class="mt-2 text-gray-600">Manage your account settings, profile image, and credentials.</p>
  </div>

  <div class="bg-white/80 backdrop-blur-xl shadow-lg rounded-2xl overflow-hidden border border-gray-100">
    <div class="p-6 md:p-8">
      <%= form_with(model: @user, url: profile_path, local: true, class: "space-y-8") do |form| %>
        <% if @user.errors.any? %>
          <div class="bg-red-50 text-red-800 p-4 rounded-xl border border-red-200">
            <h2 class="text-sm font-semibold mb-2">There were errors updating your profile:</h2>
            <ul class="list-disc pl-5 text-sm space-y-1">
              <% @user.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        <% end %>

        <div class="flex flex-col sm:flex-row gap-8 items-center sm:items-start border-b border-gray-100 pb-8">
          <div class="flex-shrink-0">
            <% if @user.profile_image.attached? %>
              <%= image_tag @user.profile_image, class: "h-32 w-32 rounded-full object-cover shadow-md border-4 border-white" %>
            <% else %>
              <div class="h-32 w-32 rounded-full bg-gray-100 flex items-center justify-center text-gray-400 border-4 border-white shadow-md">
                <svg class="h-16 w-16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                </svg>
              </div>
            <% end %>
          </div>
          
          <div class="flex-1 w-full space-y-4">
            <div>
              <%= form.label :profile_image, "Profile Image", class: "block text-sm font-semibold text-gray-700 mb-1" %>
              <%= form.file_field :profile_image, accept: "image/*", class: "block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-[#0036f3] hover:file:bg-blue-100 transition-colors" %>
            </div>
            <p class="text-xs text-gray-500">Square images work best. Max size 5MB.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6 pt-4">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <%= form.label :name, "Full Name", class: "block text-sm font-semibold text-gray-700 mb-1" %>
              <%= form.text_field :name, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-[#0036f3] focus:ring-[#0036f3] sm:text-sm" %>
            </div>
            
            <div>
              <%= form.label :email, "Email Address", class: "block text-sm font-semibold text-gray-700 mb-1" %>
              <%= form.email_field :email, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-[#0036f3] focus:ring-[#0036f3] sm:text-sm" %>
            </div>
          </div>

          <div class="border-t border-gray-100 pt-6">
            <h3 class="text-lg font-semibold text-[#1d314c] mb-4">Update Password</h3>
            <p class="text-sm text-gray-500 mb-4">Leave fields blank if you don't want to change your password.</p>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div>
                <%= form.label :password, "New Password", class: "block text-sm font-semibold text-gray-700 mb-1" %>
                <%= form.password_field :password, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-[#0036f3] focus:ring-[#0036f3] sm:text-sm" %>
              </div>
              
              <div>
                <%= form.label :password_confirmation, "Confirm New Password", class: "block text-sm font-semibold text-gray-700 mb-1" %>
                <%= form.password_field :password_confirmation, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-[#0036f3] focus:ring-[#0036f3] sm:text-sm" %>
              </div>
            </div>
          </div>
        </div>

        <div class="pt-6 flex justify-end gap-3 border-t border-gray-200 mt-8">
          <%= link_to "Cancel", root_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#0036f3] transition-colors" %>
          <%= form.submit "Save Changes", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-[#0036f3] hover:bg-blue-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#0036f3] cursor-pointer transition-colors" %>
        </div>
      <% end %>
    </div>
  </div>
</div>
