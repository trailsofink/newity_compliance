<div class="mb-8 flex flex-col md:flex-row md:items-end md:justify-between gap-4">
  <div>
    <h1 class="text-3xl font-extrabold text-[#1d314c] tracking-tight">Applications</h1>
    <p class="mt-2 text-gray-600">Overview of all loan applications and associated compliance tasks.</p>
  </div>
  
  <div class="flex items-center gap-4">
    <%= link_to "New Application", new_application_path, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-[#0036f3] hover:bg-blue-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#0036f3] transition-colors whitespace-nowrap" %>
    <div class="bg-white/80 backdrop-blur-md p-4 rounded-xl shadow-sm border border-gray-100 flex-none">
      <%= form_with url: applications_path, method: :get, local: true, class: "flex items-end gap-4" do |f| %>
      <div>
        <%= f.label :sort, "Sort By", class: "block text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1" %>
        <%= f.select :sort, 
              options_for_select([
                ["App ID (Ascending)", "app_id_asc"], 
                ["App ID (Descending)", "app_id_desc"], 
                ["Target Date (Ascending)", "target_date_asc"], 
                ["Target Date (Descending)", "target_date_desc"]
              ], params[:sort]), 
              { include_blank: "Default Sorting" }, 
              class: "mt-1 block w-full pl-3 pr-10 py-2 text-base border-gray-300 focus:outline-none focus:ring-[#0036f3] focus:border-[#0036f3] sm:text-sm rounded-md",
              onchange: "this.form.submit()" %>
      </div>
      <noscript>
        <div>
          <%= f.submit "Sort", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-[#0036f3] hover:bg-blue-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#0036f3] cursor-pointer" %>
        </div>
      </noscript>
    <% end %>
    </div>
  </div>
</div>

<div class="space-y-4">
  <% @applications.each do |application| %>
    <!-- We use a custom JS accordion to keep styles consistent without standard detail/summary marker quirks, though details is fine, JS is slightly more flexible for animations -->
    <details class="group bg-white/80 backdrop-blur-xl shadow-md rounded-2xl overflow-hidden border border-gray-100 transition-all duration-300">
      <summary class="flex items-center justify-between p-6 cursor-pointer hover:bg-gray-50/50 list-none marker:hidden focus:outline-none">
        <div class="flex items-center gap-8 w-full">
          <!-- Accordion Chevron -->
          <div class="flex-shrink-0 text-gray-400 group-open:rotate-180 transition-transform duration-300">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
            </svg>
          </div>
          
          <div class="flex-1 grid grid-cols-2 md:grid-cols-4 gap-4 items-center">
            <div>
              <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">App ID</div>
              <div class="text-sm font-medium text-gray-900"><%= link_to application.application_identifier, application_path(application), class: "hover:underline text-[#0036f3]" %></div>
            </div>
            
            <div>
              <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Borrower</div>
              <div class="text-sm text-gray-700"><%= application.borrower_name %></div>
            </div>
            
            <div class="hidden md:block">
              <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Target Closing</div>
              <div class="text-sm font-medium <%= application.target_closing_date && application.target_closing_date <= 2.weeks.from_now ? 'text-red-700' : 'text-gray-700' %>">
                <%= application.target_closing_date&.strftime("%b %d, %Y") || 'N/A' %>
              </div>
            </div>
            
            <div>
              <div class="text-xs font-semibold text-gray-500 uppercase tracking-wider mb-1">Tasks Status</div>
              <div class="text-sm flex gap-2 flex-wrap">
                <% counts = application.compliance_reviews.group(:status).count %>
                <% total = application.compliance_reviews.count %>
                <% pending = counts['Pending'].to_i %>
                <% in_review = counts['In Review'].to_i %>
                <% flagged = counts['Flagged'].to_i %>
                <% completed = total - pending - in_review - flagged %>
                
                <% if flagged > 0 %>
                  <span class="px-2 py-0.5 rounded text-xs font-semibold bg-red-100 text-red-800 border border-red-200"><%= flagged %> Flagged</span>
                <% end %>
                <% if in_review > 0 %>
                  <span class="px-2 py-0.5 rounded text-xs font-semibold bg-blue-100 text-blue-800 border border-blue-200"><%= in_review %> In Review</span>
                <% end %>
                <% if pending > 0 %>
                  <span class="px-2 py-0.5 rounded text-xs font-semibold bg-yellow-100 text-yellow-800 border border-yellow-200"><%= pending %> Pending</span>
                <% end %>
                <span class="px-2 py-0.5 rounded text-xs font-semibold bg-gray-100 text-gray-800 border border-gray-200"><%= completed %> / <%= total %> Done</span>
              </div>
            </div>
          </div>
        </div>
      </summary>

      <!-- Accordion Content -->
      <div class="border-t border-gray-100 bg-gray-50/30 overflow-x-auto p-0 m-0">
        <table class="min-w-full divide-y divide-gray-200 m-0">
          <thead class="bg-gray-100/50">
            <tr>
              <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider pl-12">Item</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Status</th>
              <th scope="col" class="px-6 py-3 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Assigned</th>
              <th scope="col" class="relative px-6 py-3"><span class="sr-only">Review</span></th>
            </tr>
          </thead>
          <tbody class="bg-white/50 divide-y divide-gray-100">
            <% application.compliance_reviews.each do |review| %>
              <% row_class = review.blocking? ? "bg-red-50/40 hover:bg-red-100/40" : "hover:bg-gray-50/60" %>
              <tr class="<%= row_class %> transition-colors">
                <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-700 pl-12">
                  <%= review.item_name %>
                </td>
                <td class="px-6 py-3 whitespace-nowrap">
                  <% status_color = case review.status
                     when 'Approved' then 'bg-green-100 text-green-800 border-green-200'
                     when 'Flagged' then 'bg-red-100 text-red-800 border-red-200'
                     when 'Pending' then 'bg-yellow-100 text-yellow-800 border-yellow-200'
                     when 'In Review' then 'bg-blue-100 text-blue-800 border-blue-200'
                     else 'bg-gray-100 text-gray-800 border-gray-200'
                     end %>
                  <span class="px-2.5 py-0.5 inline-flex text-xs leading-5 font-semibold rounded-full border <%= status_color %>">
                    <%= review.status %>
                  </span>
                </td>
                <td class="px-6 py-3 whitespace-nowrap text-sm text-gray-700">
                  <div class="flex items-center">
                    <% assignee = User.find_by(name: review.assigned_reviewer) %>
                    <% if assignee&.profile_image&.attached? %>
                      <%= image_tag assignee.profile_image, class: "h-5 w-5 rounded-full object-cover mr-2" %>
                    <% else %>
                      <div class="h-5 w-5 rounded-full bg-[#1d314c] flex items-center justify-center text-white text-[10px] mr-2 font-bold">
                        <%= review.assigned_reviewer.to_s[0] || "?" %>
                      </div>
                    <% end %>
                    <%= review.assigned_reviewer || "Unassigned" %>
                  </div>
                </td>
                <td class="px-6 py-3 whitespace-nowrap text-right text-sm font-medium">
                  <%= link_to "Review Task", edit_compliance_review_path(review), class: "text-[#0036f3] hover:text-blue-900 font-semibold" %>
                </td>
              </tr>
            <% end %>
            <% if application.compliance_reviews.empty? %>
              <tr>
                <td colspan="4" class="px-6 py-4 text-center text-sm text-gray-500 italic">No tasks found for this application.</td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </details>
  <% end %>
</div>
<style>
/* Hide the default details marker */
details > summary {
  list-style: none;
}
details > summary::-webkit-details-marker {
  display: none;
}
</style>
