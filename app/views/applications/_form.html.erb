<%= form_with(model: application, class: "space-y-8") do |form| %>
  <% if application.errors.any? %>
    <div class="bg-red-50 text-red-800 p-4 rounded-xl border border-red-200">
      <h2 class="text-sm font-semibold mb-2"><%= pluralize(application.errors.count, "error") %> prohibited this application from being saved:</h2>
      <ul class="list-disc pl-5 text-sm space-y-1">
        <% application.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <div>
      <%= form.label :application_identifier, "Application ID", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= form.text_field :application_identifier, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-[#0036f3] focus:ring-[#0036f3] sm:text-sm", placeholder: "e.g. APP-1002" %>
    </div>
    
    <div>
      <%= form.label :borrower_name, "Borrower Name", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= form.text_field :borrower_name, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-[#0036f3] focus:ring-[#0036f3] sm:text-sm", placeholder: "e.g. ACME Corp" %>
    </div>

    <div>
      <%= form.label :loan_amount, "Loan Amount", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= form.number_field :loan_amount, step: "0.01", class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-[#0036f3] focus:ring-[#0036f3] sm:text-sm", placeholder: "0.00" %>
    </div>

    <div>
      <%= form.label :target_closing_date, "Target Closing Date", class: "block text-sm font-semibold text-gray-700 mb-1" %>
      <%= form.date_field :target_closing_date, class: "block w-full rounded-md border-gray-300 shadow-sm focus:border-[#0036f3] focus:ring-[#0036f3] sm:text-sm" %>
    </div>
  </div>

  <div class="pt-6 border-t border-gray-200">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-lg font-semibold text-[#1d314c]">Initial Compliance Tasks</h3>
      <button type="button" id="add-task-btn" class="inline-flex items-center px-3 py-1.5 border border-gray-300 text-sm font-medium rounded-md shadow-sm text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#0036f3] transition-colors">
        <svg class="-ml-1 mr-1.5 h-4 w-4 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        Add Task
      </button>
    </div>

    <div id="tasks-container" class="space-y-4">
      <%= form.fields_for :compliance_reviews do |task_form| %>
        <%= render "task_fields", f: task_form %>
      <% end %>
    </div>
  </div>

  <div class="pt-6 flex justify-end gap-3 border-t border-gray-200 mt-8">
    <%= link_to "Cancel", applications_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-md text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#0036f3] transition-colors" %>
    <%= form.submit "Create Application", class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-md shadow-sm text-white bg-[#0036f3] hover:bg-blue-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-[#0036f3] cursor-pointer transition-colors" %>
  </div>
<% end %>

<script>
  // Simple listener to handle dynamic task row generation
  document.addEventListener("turbo:load", function initDynamicForms() {
    const addBtn = document.getElementById("add-task-btn");
    const container = document.getElementById("tasks-container");
    if (!addBtn || !container) return;

    // Remove old listeners to avoid duplicates on fast visits
    addBtn.replaceWith(addBtn.cloneNode(true));
    const newAddBtn = document.getElementById("add-task-btn");

    newAddBtn.addEventListener("click", () => {
      const templateElement = container.querySelector(".task-fields");
      if (!templateElement) return;

      const clone = templateElement.cloneNode(true);
      const index = new Date().getTime();
      
      clone.querySelectorAll("input, select").forEach(input => {
        if (input.name) input.name = input.name.replace(/\[\d+\]/, `[${index}]`);
        if (input.id) input.id = input.id.replace(/_\d+_/, `_${index}_`);
        if (input.tagName !== "SELECT") input.value = "";
      });

      container.appendChild(clone);
    });

    container.removeEventListener("click", removeTaskFields);
    container.addEventListener("click", removeTaskFields);
    
    function removeTaskFields(e) {
      if (e.target.closest(".remove-task-btn")) {
        const row = e.target.closest(".task-fields");
        if (container.querySelectorAll(".task-fields").length > 1) {
          row.remove();
        } else {
          row.querySelectorAll("input").forEach(input => input.value = "");
        }
      }
    }
  });
</script>
